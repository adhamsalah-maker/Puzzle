<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="24dp">

    <TextView
        android:id="@+id/titreAccueil"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Puzzle"
        android:textSize="30sp"
        android:textStyle="bold"
        android:layout_marginBottom="40dp"/>

    <Button
        android:id="@+id/btnCreerPuzzle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Créer un puzzle"
        android:layout_marginBottom="20dp"/>

    <Button
        android:id="@+id/btnMesPuzzles"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Mes puzzles"
        android:layout_marginBottom="20dp"/>

    <Button
        android:id="@+id/btnMesParties"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Mes parties"
        android:layout_marginBottom="20dp"/>

    <Button
        android:id="@+id/btnStatistiques"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Statistiques"/>

</LinearLayout>