<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:fitsSystemWindows="true"
    android:padding="4dp">

    <TextView
        android:id="@+id/tvTitreJeu"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Pièces du puzzle"
        android:textSize="14sp"
        android:textStyle="bold"
        android:layout_marginBottom="4dp" />

    <LinearLayout
        android:id="@+id/layoutRotation"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginBottom="4dp">

        <Button
            android:id="@+id/btnRotationGauche"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:minHeight="36dp"
            android:text="⟲ GAUCHE"
            android:textSize="12sp" />

        <Button
            android:id="@+id/btnRotationDroite"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:minHeight="36dp"
            android:layout_marginStart="12dp"
            android:text="DROITE ⟳"
            android:textSize="12sp" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:orientation="horizontal"
            android:gravity="center">

            <Button
                android:id="@+id/btnApercu"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_marginStart="8dp"
                android:text="👁️"
                android:textSize="14sp" />

            <Button
                android:id="@+id/btnAide"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="💡"
                android:textSize="14sp" />



            <TextView
                android:id="@+id/tvNbAides"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="3"
                android:textSize="12sp"
                android:textStyle="bold"
                android:layout_marginStart="4dp" />

        </LinearLayout>
    </LinearLayout>



    <ProgressBar
        android:id="@+id/progressBarPuzzle"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:max="100"
        android:progress="0"
        android:layout_marginBottom="2dp" />

    <TextView
        android:id="@+id/tvProgressionPourcentage"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="0%"
        android:textSize="12sp"
        android:textStyle="bold"
        android:layout_marginBottom="4dp" />

    <GridLayout
        android:id="@+id/gridPieces"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="0.6"
        android:useDefaultMargins="false"
        android:layout_marginBottom="4dp" />

    <TextView
        android:id="@+id/tvZonePuzzle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Zone de reconstruction"
        android:textSize="14sp"
        android:textStyle="bold"
        android:layout_marginBottom="4dp" />

    <GridLayout
        android:id="@+id/gridZonePuzzle"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="0.9"
        android:useDefaultMargins="false" />

</LinearLayout>